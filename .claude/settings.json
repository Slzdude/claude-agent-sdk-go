{
  "permissions": {
    "allow": [
      "Bash(go test ./...)",
      "Bash(go test -v ./...)",
      "Bash(go test -race ./...)",
      "Bash(go test -tags e2e *)",
      "Bash(go build ./...)",
      "Bash(go vet ./...)",
      "Bash(go mod tidy)",
      "Bash(gofmt -w .)",
      "Bash(golangci-lint run *)"
    ],
    "deny": []
  },
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "gofmt -w . && go vet ./..."
          }
        ],
        "matcher": "Edit|Write|MultiEdit"
      }
    ]
  }
}